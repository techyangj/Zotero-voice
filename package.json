{
  "name": "zotero-pronounce",
  "version": "0.1.7",
  "description": "A Zotero PDF reader plugin that pronounces selected text through a local OpenAI-compatible TTS endpoint.",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/techyangj/Zotero-voice.git"
  },
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "package": "npm run build && node scripts/package.mjs",
    "test": "tsx --test tests/*.test.ts",
    "tts:start": "node scripts/start-kokoro.mjs",
    "tts:stop": "node scripts/stop-kokoro.mjs",
    "clean": "rm -rf build dist/*.xpi"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
